{
  "name": "resource-monitor",
  "displayName": "Resource Monitor",
  "description": "实时监控整机 CPU、内存、磁盘、GPU，AI 给出可勾选的清理建议并一键执行。",
  "version": "0.2.1",
  "publisher": "xhqing",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/xhqing/ResourceMonitor.git"
  },
  "engines": {
    "vscode": "^1.80.0"
  },
  "categories": ["Other"],
  "icon": "assets/icon.png",
  "main": "./dist/extension.js",
  "activationEvents": ["onStartupFinished"],
  "contributes": {
    "commands": [
      {
        "command": "resourceMonitor.openPanel",
        "title": "打开资源面板",
        "category": "Resource Monitor"
      },
      {
        "command": "resourceMonitor.start",
        "title": "开始监控",
        "category": "Resource Monitor"
      },
      {
        "command": "resourceMonitor.stop",
        "title": "停止监控",
        "category": "Resource Monitor"
      },
      {
        "command": "resourceMonitor.diagnose",
        "title": "立即诊断（AI 清理建议）",
        "category": "Resource Monitor"
      },
      {
        "command": "resourceMonitor.setApiKey",
        "title": "设置 API Key",
        "category": "Resource Monitor"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "resourceMonitor",
          "title": "Resource Monitor",
          "icon": "assets/activity-icon.svg"
        }
      ]
    },
    "views": {
      "resourceMonitor": [
        {
          "id": "resourceMonitor.entry",
          "name": "资源监控",
          "type": "webview"
        }
      ]
    },
    "configuration": {
      "title": "Resource Monitor",
      "properties": {
        "resourceMonitor.interval": {
          "type": "number",
          "default": 5,
          "minimum": 1,
          "description": "巡检间隔（秒）。"
        },
        "resourceMonitor.alertCooldown": {
          "type": "number",
          "default": 300,
          "minimum": 0,
          "description": "同一资源项两次告警之间的最小间隔（秒），避免频繁打扰。默认 300（5 分钟）。"
        },
        "resourceMonitor.threshold.cpuTotal": {
          "type": "number",
          "default": 75,
          "description": "整机 CPU 占用告警阈值（%），高于此值告警。"
        },
        "resourceMonitor.threshold.cpuProcess": {
          "type": "number",
          "default": 80,
          "description": "单进程 CPU 告警阈值（%），高于此值告警。"
        },
        "resourceMonitor.threshold.memoryFree": {
          "type": "number",
          "default": 20,
          "description": "内存可用率告警阈值（%），低于此值告警。"
        },
        "resourceMonitor.threshold.diskUsed": {
          "type": "number",
          "default": 85,
          "description": "磁盘使用率告警阈值（%），高于此值告警。"
        },
        "resourceMonitor.ai.baseUrl": {
          "type": "string",
          "default": "https://api.z.ai/api/anthropic",
          "description": "AI 接口 Base URL（默认 z.ai 的 Anthropic 兼容端点）。"
        },
        "resourceMonitor.ai.model": {
          "type": "string",
          "default": "glm-5.2",
          "description": "AI 模型 ID。"
        },
        "resourceMonitor.ai.protocol": {
          "type": "string",
          "enum": ["anthropic", "openai"],
          "default": "anthropic",
          "description": "AI 接口协议：anthropic（/v1/messages）或 openai（兼容）。"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.js",
    "watch": "node esbuild.js --watch",
    "package": "vsce package"
  },
  "devDependencies": {
    "@types/node": "^18.0.0",
    "@types/vscode": "^1.80.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0"
  }
}
